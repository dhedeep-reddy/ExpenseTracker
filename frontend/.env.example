# Frontend Environment Variables
# Copy this to .env.local for local dev, or set in Vercel project settings for production

# Your Render backend URL (no trailing slash)
# Local dev — leave as-is:
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Production — set this in your Vercel dashboard (Settings → Environment Variables):
# NEXT_PUBLIC_API_URL=https://<your-service-name>.onrender.com/api
#
# After changing the value in Vercel, redeploy the frontend to pick up the new URL.
